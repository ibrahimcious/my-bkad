  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^5.22.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.13"
