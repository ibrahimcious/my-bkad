# Copy this file to .env for local development. .env is gitignored.

# PostgreSQL connection used by Prisma. The default value matches the
# credentials in docker-compose.yml.
DATABASE_URL="postgresql://bkad:bkad_dev_password@localhost:5432/bkad?schema=public"

# Secret used to seal (encrypt + sign) the session cookie. Generate a
# random string of at least 32 characters, e.g. `openssl rand -base64 32`.
SESSION_PASSWORD="replace-with-a-random-string-at-least-32-characters-long"

# Optional. Override the seed account passwords for a production deploy.
# When unset, the seed falls back to the development passwords in
# prisma/seed.ts. Set these before running the seed in production.
# SEED_KEPALA_PASSWORD=""
# SEED_SEKRETARIS_PASSWORD=""
# SEED_UPLOADER_PASSWORD=""
