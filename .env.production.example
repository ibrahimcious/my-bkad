# Production environment for the BKAD Pasuruan dashboard.
#
# Copy this file to `.env.production` and fill in real values.
# `.env.production` holds secrets — it is gitignored; never commit it.

# --- Database ------------------------------------------------------------
# Read by docker-compose.prod.yml to provision the Postgres container.
POSTGRES_USER=bkad
POSTGRES_PASSWORD=
POSTGRES_DB=bkad

# Connection string used by the app and by Prisma migrations. The host is
# the compose service name `postgres`. The user/password/db must match the
# three values above.
DATABASE_URL="postgresql://bkad:CHANGE_ME@postgres:5432/bkad?schema=public"

# --- Session -------------------------------------------------------------
# Secret that seals the session cookie. At least 32 characters.
# Generate with:  openssl rand -base64 32
SESSION_PASSWORD=

# --- Seed account passwords ----------------------------------------------
# Used by `pnpm db:seed` to set the three v1 accounts' passwords.
# Set strong values before seeding in production.
SEED_KEPALA_PASSWORD=
SEED_SEKRETARIS_PASSWORD=
SEED_UPLOADER_PASSWORD=

# --- Error tracking ------------------------------------------------------
# Sentry DSN. Leave blank to disable error tracking. Note: Sentry's SaaS
# ingests events outside Indonesia — see the data-residency note in
# docs/deploy.md before enabling.
SENTRY_DSN=

# --- Runtime -------------------------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
